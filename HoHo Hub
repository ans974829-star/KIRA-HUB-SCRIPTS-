-- Check if key exists in getgenv()
local function CheckStoredKey()
    local success, storedKey = pcall(function()
        if getgenv and getgenv().KiraKey then
            return getgenv().KiraKey
        end
        return nil
    end)
    
    if success and storedKey then
        print("[KIRA] Found stored key in getgenv()")
        return storedKey
    end
    
    return nil
end

-- Validate key function
local function ValidateKey(key)
    return key == Config.CorrectKey
end

-- Auto-verify if key is stored
local storedKey = CheckStoredKey()
if storedKey and ValidateKey(storedKey) then
    print("[KIRA] ✓ Stored key validated successfully!")
    print("[KIRA] Auto-authenticating...")
    ExecuteMainScript()
    return
else
    if storedKey then
        print("[KIRA] ✗ Stored key is invalid or expired")
        -- Clear invalid key
        pcall(function()
            getgenv().KiraKey = nil
        end)
    end
    print("[KIRA] No valid stored key found, showing GUI...")
end

