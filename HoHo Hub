-- Verify Button
VerifyBtn.MouseButton1Click:Connect(function()
    local key = KeyInput.Text
    
    if key == "" then
        ShowNotification("Please enter a key", true)
        return
    end
    
    VerifyBtn.Text = "VERIFYING..."
    VerifyBtn.BackgroundColor3 = Config.InputBackground
    
    task.wait(0.8)
    
    if ValidateKey(key) then
        print("[KIRA] ✓ Correct key!")
        VerifyBtn.Text = "ACCESS GRANTED"
        VerifyBtn.BackgroundColor3 = Config.SuccessColor
        
        -- Save key to getgenv if checkbox is checked
        if rememberKey then
            pcall(function()
                getgenv().KiraKey = key
                print("[KIRA] ✓ Key saved to getgenv()")
                ShowNotification("Key saved! You won't need to enter it next time", false)
            end)
        else
            ShowNotification("Authentication successful", false)
        end
        
        task.wait(1.5)
        
        ScreenGui:Destroy()
        
        ExecuteMainScript()
    else
        print("[KIRA] ✗ Wrong key!")
        VerifyBtn.Text = "INVALID KEY"
        VerifyBtn.BackgroundColor3 = Config.ErrorColor
        ShowNotification("Authentication failed - Invalid key", true)
        
        task.wait(1.2)
        
        VerifyBtn.Text = "VERIFY KEY"
        VerifyBtn.BackgroundColor3 = Config.AccentColor
        KeyInput.Text = ""
    end
end)

