-- Button Hover Effects
local function SetupButton(button, isAccent)
    local originalColor = button.BackgroundColor3
    local hoverColor = isAccent and Color3.fromRGB(200, 200, 200) or Color3.fromRGB(32, 32, 32)
    
    button.MouseEnter:Connect(function()
        Tween(button, {BackgroundColor3 = hoverColor}, 0.2)
    end)
    
    button.MouseLeave:Connect(function()
        Tween(button, {BackgroundColor3 = originalColor}, 0.2)
    end)
end

