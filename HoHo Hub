local function Tween(object, properties, duration)
    local tween = TweenService:Create(
        object,
        TweenInfo.new(duration or 0.3, Enum.EasingStyle.Quint, Enum.EasingDirection.Out),
        properties
    )
    tween:Play()
    return tween
end

local function ShowNotification(message, isError)
    StatusBar.BackgroundColor3 = isError and Config.ErrorColor or Config.SuccessColor
    StatusBar.Visible = true
    
    Tween(StatusBar, {Size = UDim2.new(1, 0, 0, 3)}, 0.2)
    
    local NotifText = Instance.new("TextLabel")
    NotifText.Size = UDim2.new(1, -40, 0, 30)
    NotifText.Position = UDim2.new(0, 20, 1, -35)
    NotifText.BackgroundTransparency = 1
    NotifText.Font = Enum.Font.GothamMedium
    NotifText.Text = message
    NotifText.TextColor3 = isError and Config.ErrorColor or Config.SuccessColor
    NotifText.TextSize = 11
    NotifText.TextXAlignment = Enum.TextXAlignment.Left
    NotifText.TextTransparency = 0
    NotifText.ZIndex = 7
    NotifText.Parent = MainContainer
    
    task.wait(2.5)
    
    Tween(NotifText, {TextTransparency = 1}, 0.2)
    Tween(StatusBar, {Size = UDim2.new(1, 0, 0, 0)}, 0.2)
    
    task.wait(0.2)
    NotifText:Destroy()
    StatusBar.Visible = false
end

